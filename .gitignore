# ==========================================
# 🎵 UtaSync 专属核心配置
# ==========================================
# 忽略所有媒体文件
*.mp4
*.mkv
*.wav
*.mp3
*.flac

# 忽略输出和巨大媒体目录 (防止 Git 卡死)
output/
input/video/
input/audio/

# 忽略下载的大模型权重文件 (极大文件，严禁上传)
models_faster/
models/

# 忽略打轴临时文件、翻译指纹哈希缓存
*.srt
*.ass
*.hash
temp_lyrics_gui.txt
temp_style_preview.html

# ⚠️ 保护私有歌词文件，但保留给新用户的范本
input/lyrics/*.txt
!input/lyrics/参考歌词_范本.txt

# ⚠️ 保护本地设置与 API Key（极度危险，绝不上传！）
user_settings.json
!config.json

# ==========================================
# 📦 打包产物与设计工程 (勿传云端)
# ==========================================
# 忽略图标设计文件夹及草图
icon/
source.jpg

# 忽略 PyInstaller 打包生成的临时文件和最终独立成品
build/
dist/
*.spec

# ==========================================
# 🐍 Python 虚拟环境与编译缓存
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# 忽略虚拟环境文件夹 
venv/
.venv/
env/
.env
env_build/
env_gui/

# ==========================================
# 💻 操作系统与 IDE 编辑器缓存
# ==========================================
# Mac / Win 系统垃圾
.DS_Store
Thumbs.db

# 忽略代码编辑器生成的专属配置文件夹
.vscode/
.idea/
.cursor/